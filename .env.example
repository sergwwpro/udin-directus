# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.example is committed for onboarding.

# Postgres password for Directus DB (random string, local only)
POSTGRES_PASSWORD=

# Directus secrets — required. Generate with: openssl rand -hex 16 / 32
DIRECTUS_KEY=
DIRECTUS_SECRET=

# Seed admin credentials — used once on first docker up to create the
# initial admin user. Change the password in the UI immediately after.
DIRECTUS_ADMIN_EMAIL=
DIRECTUS_ADMIN_PASSWORD=

# Admin token — for Directus MCP + schema management.
# Generate in Directus UI → User Directory → your admin user → Token.
DIRECTUS_ADMIN_TOKEN=

# API token — for Next.js runtime. Tied to the "Public API" role
# with read-only permissions on content collections.
DIRECTUS_API_TOKEN=

# Public Directus URL. Use localhost for local dev.
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Shared secret for /api/revalidate webhook (Directus → Next.js).
# Generate with: openssl rand -hex 32
REVALIDATE_SECRET=
